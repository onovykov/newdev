<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_CrossMarket_AllOrNothing</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
  CrossMarketTouched__c,
  NOT(CrossMarketComplete__c)
)</errorConditionFormula>
    <errorMessage>Крос-маркет має бути або повністю заповнений (усі 3 поля), або порожній</errorMessage>
</ValidationRule>

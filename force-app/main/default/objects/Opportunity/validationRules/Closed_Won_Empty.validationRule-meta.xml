<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Closed_Won_Empty</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    ISPICKVAL(StageName, &quot;Closed Won&quot;),
    ItemsCount__c = 0
)</errorConditionFormula>
    <errorMessage>You cannot set Closed Won stage with empty Opportinity Products list</errorMessage>
</ValidationRule>

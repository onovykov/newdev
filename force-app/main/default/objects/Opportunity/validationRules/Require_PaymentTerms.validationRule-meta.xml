<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_PaymentTerms</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
  IsBlank(PaymentTerms__c),
  ISPICKVAL(MarketSegment__c, &apos;00004&apos;)
)
&amp;&amp; $Profile.Name &lt;&gt; &quot;System Administrator&quot;</errorConditionFormula>
    <errorMessage>Payment Terms is required</errorMessage>
</ValidationRule>

<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CrossMarketTouched__c</fullName>
    <formula>OR(
  NOT(ISBLANK(CrossMarketManager__c)),
  NOT(ISBLANK(TEXT(CrossMarketSegment__c))),
  NOT(ISBLANK(CrossMarketShare__c))
)</formula>

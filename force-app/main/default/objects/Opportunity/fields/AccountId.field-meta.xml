<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>AccountId</fullName>
    <lookupFilter>
        <active>true</active>
        <errorMessage>❌ You cannot create an Opportunity for accounts with activity type Unknown, Banned, or Cancelled</errorMessage>
        <filterItems>
            <field>Account.Activity_Type__c</field>
            <operation>notEqual</operation>
            <value>Unknown, Banned, Cancelled</value>
        </filterItems>
        <isOptional>false</isOptional>
    </lookupFilter>
    <trackFeedHistory>false</trackFeedHistory>
    <trackHistory>true</trackHistory>
    <type>Lookup</type>
</CustomField>

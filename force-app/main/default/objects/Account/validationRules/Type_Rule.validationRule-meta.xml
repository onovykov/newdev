<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Type_Rule</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
ISPICKVAL(Type,&apos;Inner Firm&apos;)
)
&amp;&amp; $Profile.Name &lt;&gt; &quot;System Administrator&quot;</errorConditionFormula>
    <errorMessage>Only System Administrator can set the value &quot;Inner Firm&quot; in the &quot;Type&quot; field</errorMessage>
</ValidationRule>

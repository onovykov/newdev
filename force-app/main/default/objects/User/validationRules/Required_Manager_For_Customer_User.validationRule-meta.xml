<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Required_Manager_For_Customer_User</fullName>
    <active>true</active>
    <description>Required Manager For Customer Community User</description>
    <errorConditionFormula>AND(Profile.Name=&apos;Customer Community User (Custom)&apos;,
ISBLANK( ManagerId ) )</errorConditionFormula>
    <errorDisplayField>ManagerId</errorDisplayField>
    <errorMessage>Customer Community User can not contain empty Manager field</errorMessage>
</ValidationRule>

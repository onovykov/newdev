<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>creator</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <submitter>sf-ite@interpipe.biz</submitter>
        <type>user</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Account__c</field>
        <field>Quantity_t__c</field>
        <field>Price_t__c</field>
        <field>Revenue__c</field>
        <field>SalesRep__c</field>
        <field>IsPriceModel__c</field>
        <field>MarketSegment__c</field>
        <field>PaymentTerms__c</field>
        <field>DeliveryTerms__c</field>
        <field>Liabilities__c</field>
        <field>Liabilities_t__c</field>
        <field>CurrencyIsoCode</field>
        <field>Owner</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>SalesRep__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <description>Confirmation by Sales Rep</description>
        <label>Sales Rep</label>
        <name>Sales_Rep</name>
    </approvalStep>
    <description>Price Approval Request - confirmation by Sales Rep.</description>
    <emailTemplate>unfiled$public/PAR_Approval</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <finalApprovalActions>
        <action>
            <name>Set_PAR_Approved_by_Sales_Rep</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Set_PAR_Rejected_by_Sales_Rep</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <label>PAR - Sales Rep</label>
    <processOrder>1</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>

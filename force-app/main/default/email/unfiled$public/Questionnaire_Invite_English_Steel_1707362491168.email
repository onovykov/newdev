<!DOCTYPE html><html> <head>  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />  <meta name="viewport" content="width=device-width, initialscale=1.0" />  <meta http-equiv="X-UA-Compatible" content="IE=edge" />  <style type="text/css">@media screen and (max-width: 480px) {slot[style] {margin-right: 0 !important;}.columnDiv {margin-right: 0 !important;}}@media screen and (min-width: 480px) {slot[style] {margin-bottom: 0 !important;}.columnDiv {margin-bottom: 0 !important;}}</style>  <style type="text/css">@media screen and (max-width: 480px) {.contentbuilderBaseColumnRow .columnCell {display:inline-block;width:100%}}</style>  <style type="text/css">.contentpageDefaultEmailTemplatePageTemplate .contentRoot {width: 600px;}@media only screen and (max-width: 480px) {.contentpageDefaultEmailTemplatePageTemplate .contentRoot {width: 320px;}}</style> </head> <body>  <table class="contentpageDefaultEmailTemplatePageTemplate" style="background-color: #E9EAEC;" role="presentation" id="contentpage_emailTemplateBodyContent" width="100%" cellpadding="0" cellspacing="0">       <tr>     <td width="100%" align="center">      <table class="contentRoot" style="background-color: #FFFFFF;" role="presentation" width="600" cellpadding="0" cellspacing="0">               <tr>         <td style="padding-top: 10px; padding-bottom: 10px; padding-left: 10px; padding-right: 10px;">          <table class="contentbuilderBaseColumnRow" style="align-items: flex-start; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="top">             <td width="33.33%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="font-size:14px; width: 100%; border-collapse: collapse; word-break: break-word;" role="presentation" cellspacing="0" cellpadding="0" id="contentregion" locked="0">                                         <tr>                      <td class="contentbuilder-html" style="padding: 0;"><img src="https://ecnccgi.stripocdn.email/content/guids/CABINET_0eaafd4fced20c7788b7648b28ef49cfab550ad03f770ac597db26b17b87e22e/images/interpipe_steel.png" alt="" class="img-5255" width="180" style="display:block;font-size:14px;border:0;outline:none;text-decoration:none" /></td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>             <td width="66.66%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <div class="columnDiv" style="margin-right: 5px;margin-bottom: 5px;">               <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                                 <tr>                  <td>                   <table style="font-size:14px; width: 100%; border-collapse: collapse; word-break: break-word;" role="presentation" cellspacing="0" cellpadding="0" id="contentregion" locked="0">                                         <tr>                      <td class="contentbuilder-html" style="padding: 0;"><a href="https://interpipe.biz/en/"><img src="https://ci5.googleusercontent.com/proxy/te39iWRapV93eNangwbBO8MhmN47tE9Uoaa_W04QfR5IG_9RjGnVrmgJNrNTxjcyJo4GRPYQyHmu_nj9CG1nKdsFWOauSaEbGinpTRAdx9WCkOGEgyIAswSJB_vMKi2VCS5OwkLkFZpnONGFIP6XDZZKArhyVxghlMC67jrisSUM0A3KJO8gkM56cE0HV817Em5Y-9bU20kKKxmrLB94LXSUT9XHtvXh=s0-d-e1-ft#https://ecnccgi.stripocdn.email/content/guids/CABINET_0eaafd4fced20c7788b7648b28ef49cfab550ad03f770ac597db26b17b87e22e/images/ip_illustration_22.JPG" alt="" width="360" class="m_adapt-img" style="display:block;font-size:14px;border:0;outline:none;text-decoration:none" /></a></td>                     </tr>                                       </table></td>                 </tr>                               </table>              </div></td>            </tr>                     </table>          <table class="contentbuilderBaseColumnRow" style="align-items: flex-start; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="top">             <td width="100%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                               <tr>                 <td>                  <table style="width: 100%; border-collapse: collapse; word-break: break-word; font-size: 14px" id="contentRegion" role="presentation" cellspacing="0" cellpadding="0" locked="0">                                       <tr>                     <td style="font-family: Arial, Helvetica, sans-serif;"><p><span style="font-size:16px;">{{{Questionnaire_Response__c.Salutation__c}}} {{{Questionnaire_Response__c.Respondent__c}}},</span></p><p><span style="font-size:16px;">We greatly value your partnership with Interpipe, and your feedback plays a key role in helping us improve. Each year, we conduct a Client Satisfaction Survey, and we would love for you to participate as one of our shortlisted clients.<br /> &nbsp;<br /> To make it easy and convenient, the survey is available online and will take no more than 10 minutes of your time. Your insights will help us enhance your experience and continue moving in the right direction.<br /> &nbsp;<br /> If you have any questions, feel free to reach out to our marketing team by replying to this email. Thank you in advance for your time—we truly appreciate it!</span><br /><br /> &nbsp;</p></td>                    </tr>                                     </table></td>                </tr>                             </table></td>            </tr>                     </table>          <table class="contentbuilderBaseColumnRow" style="align-items: flex-start; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="top">             <td width="100%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                               <tr>                 <td>                  <table style="font-size:14px; width: 100%; border-collapse: collapse; word-break: break-word;" role="presentation" cellspacing="0" cellpadding="0" id="contentregion" locked="0">                                       <tr>                     <td class="contentbuilder-html" style="padding: 0;">                      <table style="width: 100%; border-collapse: collapse;">                                               <tr>                         <td style="text-align: left; vertical-align: middle;"><p>Respectfully, <br /> Yuliya Kozachenko <br />________________ <br /><strong>Head of Marketing <br /> Interpipe | Interpipe Steel</strong><br /> yuliya.kozachenko@m.interpipe.biz <br /> +38 (056) 7474 797</p></td>                         <td style="text-align: right; vertical-align: top;"><a href="https://interpipe.my.site.com/NewCustomerRoom/s/survey?recordId={{{Questionnaire_Response__c.Id}}} " style="text-decoration:none!important;color:#ffffff;font-size:18px;padding:10px 20px 10px 20px; height:20px;display:inline-block;background:#31cb4b;border-radius:30px;font-family:arial,'helvetica neue',helvetica,sans-serif;font-weight:normal;font-style:normal;line-height:22px;width:auto;text-align:center;letter-spacing:0;margin-right:10px; margin-top:0.5em" rel="noreferrer ">Take Survey</a></td>                        </tr>                                             </table></td>                    </tr>                                     </table></td>                </tr>                             </table></td>            </tr>                     </table>          <table class="contentbuilderBaseColumnRow" style="align-items: flex-start; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="top">             <td width="100%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                               <tr>                 <td>                  <table style="font-size:14px; width: 100%; border-collapse: collapse; word-break: break-word;" role="presentation" cellspacing="0" cellpadding="0" id="contentregion" locked="0">                                       <tr>                     <td class="contentbuilder-html" style="padding: 0;"><a href="https://zadnipro.dp.ua/en"><img src="https://ecnccgi.stripocdn.email/content/guids/CABINET_0eaafd4fced20c7788b7648b28ef49cfab550ad03f770ac597db26b17b87e22e/images/support_ukraine_image.JPG" alt="" width="560" class="m_adapt-img" style="display:block;font-size:14px;border:0;outline:none;text-decoration:none" /></a></td>                    </tr>                                     </table></td>                </tr>                             </table></td>            </tr>                     </table></td>        </tr>             </table></td>    </tr>     </table> </body></html>
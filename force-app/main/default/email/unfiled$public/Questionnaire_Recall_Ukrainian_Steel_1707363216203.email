lderBaseColumnRow" style="align-items: flex-start; width: 100%; background-color:;" role="presentation" width="100%" cellpadding="0" cellspacing="0">                       <tr valign="top">             <td width="100%" class="columnCell" style="vertical-align: top;display: inline-block; float:left">              <table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; word-break:break-word;">                               <tr>                 <td>                  <table style="font-size:14px; width: 100%; border-collapse: collapse; word-break: break-word;" role="presentation" cellspacing="0" cellpadding="0" id="contentregion" locked="0">                                       <tr>                     <td class="contentbuilder-html" style="padding: 0;"><a href="https://zadnipro.dp.ua/en"><img src="https://ecnccgi.stripocdn.email/content/guids/CABINET_0eaafd4fced20c7788b7648b28ef49cfab550ad03f770ac597db26b17b87e22e/images/support_ukraine_image.JPG" alt="" width="560" class="m_adapt-img" style="display:block;font-size:14px;border:0;outline:none;text-decoration:none" /></a></td>                    </tr>                                     </table></td>                </tr>                             </table></td>            </tr>                     </table></td>        </tr>             </table></td>    </tr>     </table> </body></html>